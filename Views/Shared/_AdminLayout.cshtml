<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>پنل مدیریت - @ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap-v4-rtl-master/dist/css/bootstrap-rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow-y: hidden;
        }

        h5 {
            color: white;
            white-space: nowrap;
        }

        path {
            fill: white;
        }

        .wrapper {
            height: 100vh;
            display: flex;
        }

        .admin-sidebar {
            min-width: 240px;
            background: #343a40;
            transition: margin 0.3s ease, width 0.3s ease;
        }

        .admin-sidebar.collapsed {
            margin-right: -240px;
        }

        .admin-header {
            background: #fff;
        }

        .admin-content {
            padding: 20px;
            overflow-y: auto;
            flex-grow: 1;
        }

        .admin-sidebar a {
            display: flex;
            align-items: center;
            justify-content: start;
            gap: 40px;
            padding: 15px 18px;
            color: white;
            text-decoration: none;
        }

        .admin-sidebar a:hover {
            background: gray;
        }
    </style>
</head>

<body>

    <div class="wrapper">

        <!-- Sidebar -->
        <div class="admin-sidebar bg-dark">
            <h5 class="p-3 mb-3 text-center">مدیریت فروشگاه</h5>

            <a asp-controller="Admin" asp-action="User">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="20" width="20">
                    <path d="M12 0C7.582031 0 4 3.582031 4 8C4 12.417969 7.582031 16 12 16C16.417969 16 20 12.417969 20 8C20 3.582031 16.417969 0 12 0 Z M 6.65625 10.65625L17.34375 10.65625C16.359375 12.625 14.351563 14 12 14C9.648438 14 7.640625 12.625 6.65625 10.65625 Z M 7.375 17.375C4.398438 18.15625 2.070313 20.015625 1 24L23 24C21.929688 20.015625 19.601563 18.15625 16.625 17.375C15.246094 18.113281 13.671875 18.53125 12 18.53125C10.328125 18.53125 8.753906 18.113281 7.375 17.375Z"/>
                </svg>
                <span>لیست کاربران</span>
            </a>

            <a asp-controller="Admin" asp-action="Product">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="20" width="20">
                    <path xmlns="http://www.w3.org/2000/svg" d="M23.398438 1.5C25.601563 3.699219 21.101563 8.898438 15.101563 15C9 21.101563 3.699219 25.601563 1.5 23.5C-1.5 20.601563 0.800781 14.800781 1.699219 13.398438C1.898438 13.101563 7.199219 14.601563 8.101563 13.800781C8.898438 13.101563 4.199219 10.699219 2.101563 12.300781C2.300781 9.101563 4.601563 8.800781 5.199219 8.398438C6.199219 7.601563 12.398438 10.699219 13.398438 9.601563C14.5 8.398438 8 6 6.5 7.300781C6.699219 4 9.898438 4.699219 10.699219 4C11.300781 3.5 16.5 6 17.5 5.101563C18.5 4.199219 13.5 2.398438 11.898438 3C13.300781 0.5 15 1.398438 15.601563 1.101563C19.398438 -0.601563 21.800781 -0.199219 23.398438 1.5Z"/>
                </svg>
                <span>لیست محصولات</span>
            </a>

            <a asp-controller="Admin" asp-action="Category">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="20" width="20">
                    <path xmlns="http://www.w3.org/2000/svg" d="M0 3L0 21L20.53125 21L24 9L4 9L2 16L1.4375 15.3125L3.09375 8L21 8L21 6L9 6L7.21875 3Z" fill="#FFFFFF"/>
                </svg>
                <span>دسته‌بندی‌ها</span>
            </a>

            <a asp-controller="Home" asp-action="Index">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="20" width="20">
                    <path xmlns="http://www.w3.org/2000/svg" d="M1 0L1 2L23 2L23 0L1 0 z M 1 3C1 3 0 9.326 0 9.5C0 10.328 0.672 11 1.5 11C2.328 11 3 10.328 3 9.5L3 5L5.25 5L5.25 9.5C5.25 10.328 5.922 11 6.75 11C7.578 11 8.25 10.328 8.25 9.5L8.25 5L10.5 5L10.5 9.5C10.5 10.328 11.172 11 12 11C12.828 11 13.5 10.328 13.5 9.5L13.5 5L15.75 5L15.75 9.5C15.75 10.328 16.422 11 17.25 11C18.078 11 18.75 10.328 18.75 9.5L18.759766 5L21 5L21 9.5C21 10.328 21.672 11 22.5 11C23.328 11 24 10.328 24 9.5C24 9.326 23 3 23 3L1 3 z M 4.125 10.501953C3.613 11.424953 2.628 12.050781 1.5 12.050781C1.329 12.050781 1.163 12.028 1 12L1 24L14 24L14 14L20 14L20 24L23 24L23 12.001953C22.837 12.029953 22.671 12.050781 22.5 12.050781C21.372 12.050781 20.388 11.425906 19.875 10.503906C19.363 11.425906 18.378 12.050781 17.25 12.050781C16.122 12.050781 15.137 11.424953 14.625 10.501953C14.113 11.424953 13.128 12.050781 12 12.050781C10.872 12.050781 9.887 11.424953 9.375 10.501953C8.863 11.424953 7.878 12.050781 6.75 12.050781C5.622 12.050781 4.637 11.424953 4.125 10.501953 z M 4 14L11 14L11 20L4 20L4 14 z"/>
                </svg>
                <span>بازگشت به فروشگاه</span>
            </a>

            <a asp-controller="Account" asp-action="Logout">
                 <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" height="20" width="20">
                    <path xmlns="http://www.w3.org/2000/svg" d="M5 3C3.897 3 3 3.897 3 5L3 25C3 26.103 3.897 27 5 27L19 27C20.103 27 21 26.103 21 25L21 16L13 16C12.448 16 12 15.552 12 15C12 14.448 12.448 14 13 14L21 14L21 5C21 3.897 20.103 3 19 3L5 3 z M 21 14L21 16L26.585938 16L24.292969 18.292969 A 1.0001 1.0001 0 1 0 25.707031 19.707031L29.707031 15.707031 A 1.0001 1.0001 0 0 0 29.707031 14.292969L25.707031 10.292969 A 1.0001 1.0001 0 0 0 24.990234 9.9902344 A 1.0001 1.0001 0 0 0 24.292969 11.707031L26.585938 14L21 14 z"/>
                </svg>
                <span>خروج از حساب</span>
            </a>
        </div>

        <!-- Right side -->
        <div class="d-flex flex-column flex-grow-1">

            <!-- Header -->
            <div class="admin-header p-3 d-flex align-items-center bg-dark">

                <button id="sidebarToggle" class="btn btn-dark mr-3">
                    ☰
                </button>

                <h5 class="m-0">@ViewData["Title"]</h5>
            </div>

            <!-- Page Content -->
            <div class="admin-content">
                @RenderBody()
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap-v4-rtl-master/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $("#sidebarToggle").on("click", function () {
            $(".admin-sidebar").toggleClass("collapsed");
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>پویا مارکت - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap-v4-rtl-master/dist/css/bootstrap-rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyEshop.styles.css" asp-append-version="true" />
</head>
<body class="rtl">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light border-bottom">
            <div class="container">
                <a asp-controller="Home" asp-action="Index" class="navbar-brand text-success" style="font-weight: 800;">پویا مارکت</a>
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarColor03" aria-controls="navbarColor03" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarColor03">
                    <ul class="navbar-nav mr-lg-auto m-0 p-0">
                        <li class="nav-item active">
                            <a class="nav-link" href="#"></a>
                        </li>
                        <li class="nav-item active">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">محصولات</a>
                        </li>
                        <li class="nav-item active">
                            <a class="nav-link" asp-controller="Cart" asp-action="Cart">سبد خرید</a>
                        </li>
                        <li class="nav-item dropdown active">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                حساب کاربری
                            </a>
                            <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                                @if (User.Identity.IsAuthenticated)
                                {
                                    @if (User.FindFirst("IsAdmin")?.Value == "True")
                                    {
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Index">پنل ادمین</a>
                                    }
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Account">اطلاعات کاربری</a>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Logout">خروج از حساب</a>
                                }
                                else
                                {
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Login">ورود</a>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Register">ثبت‌نام</a>
                                }
                            </div>
                        </li>
                    </ul>
                    <form method="get" asp-controller="Home" asp-action="SearchProduct" class="d-flex align-items-center my-2 my-lg-0">
                        <input class="form-control mr-2" type="text" name="value" placeholder="جستجو محصول">
                        <button class="btn btn-success my-2 my-sm-0" type="submit">جستجو</button>
                    </form>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            <section>@RenderBody()</section>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap-v4-rtl-master/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

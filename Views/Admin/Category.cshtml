@model IEnumerable<Category>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "دسته‌بندی‌ها";
}

<div class="table-responsive pb-5" style="white-space: nowrap;">
    <a asp-control="Admin" asp-action="AddCategory" class="btn btn-dark mb-3" style="float: right;">افزودن دسته‌بندی</a>
    <table class="table table-bordered table-sm text-center">
        <thead class="thead-dark">
            <tr>
                <th>نام دسته‌بندی</th>
                <th>توضیحات</th>
                <th>تعداد محصول</th>
                <th>عملیات</th>
            </tr>
        </thead>

        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@(item.Description == "" ? "ندارد" : item.Description)</td>
                    <td>@item.Products.Count عدد</td>
                    <td>
                        <a asp-control="Admin" asp-action="EditCategory" asp-route-id="@item.Id" class="btn btn-sm btn-dark">ویرایش</a>
                        <a asp-control="Admin" asp-action="DeleteCategory" asp-route-id="@item.Id" class="btn btn-sm btn-danger">حذف</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

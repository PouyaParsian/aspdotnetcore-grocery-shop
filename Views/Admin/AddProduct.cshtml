@model AddEditProductViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "افزودن محصول";
}

<div class="py-5" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-10">

            <div class="card border">
                <div class="card-header bg-dark text-center">
                    <h5 class="pt-2 fw-bold" style="font-weight: 800;">ایجاد محصول جدید</h5>
                </div>

                <div class="card-body">

                    <form asp-action="AddProduct" asp-controller="Admin" method="post" enctype="multipart/form-data">
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" style="max-height: 100px; min-height: 50px;"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="CategoryId"></label>
                            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control">
                                <option value="0">انتخاب دسته‌بندی</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label"></label>
                            <input asp-for="Price" type="number" class="form-control" min="0" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="QuantityInStock" class="form-label"></label>
                            <input asp-for="QuantityInStock" type="number" class="form-control" min="0" />
                            <span asp-validation-for="QuantityInStock" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Picture" class="form-label"></label>
                            <br />
                            <input asp-for="Picture" type="file" accept="image/webp" />
                            <br />
                            <span asp-validation-for="Picture" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark w-100">ایجاد محصول</button>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script>
    document.getElementById("Price").addEventListener("input", function () {
        this.value = this.value.replace(/[^0-9]/g, '');
    });
    document.getElementById("QuantityInStock").addEventListener("input", function () {
        this.value = this.value.replace(/[^0-9]/g, '');
    });
</script>
@model RegisterViewModel

@{
    ViewData["Title"] = "ثبت‌نام";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-10">

            <div class="card border">
                <div class="card-header bg-light text-center">
                    <h5 class="pt-2 fw-bold" style="font-weight: 800;">ایجاد حساب کاربری</h5>
                </div>

                <div class="card-body">

                    <form asp-action="Register" asp-controller="Account" method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RePassword" class="form-label"></label>
                            <input asp-for="RePassword" class="form-control" />
                            <span asp-validation-for="RePassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 mt-3">ایجاد حساب</button>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}